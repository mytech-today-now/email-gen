{
  "ignorePathPatterns": [
    "^\\.git(?:/|$)",
    "^node_modules(?:/|$)",
    "^coverage(?:/|$)",
    "^logs(?:/|$)",
    "^output(?:/|$)",
    "^playwright-report(?:/|$)",
    "^test-results(?:/|$)",
    "^storage(?:/|$)",
    "^\\.inspect(?:/|$)"
  ],
  "binaryExtensions": [
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".webp",
    ".ico",
    ".pdf",
    ".zip",
    ".gz",
    ".sqlite",
    ".woff",
    ".woff2"
  ],
  "patterns": [
    {
      "name": "private_key",
      "regex": "-----BEGIN (?:RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY-----"
    },
    {
      "name": "github_token",
      "regex": "\\bgh[pousr]_[A-Za-z0-9]{20,}\\b"
    },
    {
      "name": "openai_like_secret",
      "regex": "\\bsk-(?!test\\b|mock\\b|example\\b|fake\\b)[A-Za-z0-9_-]{20,}\\b"
    },
    {
      "name": "aws_access_key",
      "regex": "\\bAKIA[0-9A-Z]{16}\\b"
    },
    {
      "name": "google_api_key",
      "regex": "\\bAIza[0-9A-Za-z\\-_]{35}\\b"
    },
    {
      "name": "slack_token",
      "regex": "\\bxox[baprs]-[A-Za-z0-9-]{10,}\\b"
    },
    {
      "name": "webhook_secret",
      "regex": "\\bwhsec_[A-Za-z0-9+/=]{20,}\\b"
    }
  ]
}
